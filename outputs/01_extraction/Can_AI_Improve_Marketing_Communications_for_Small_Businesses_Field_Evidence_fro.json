{
  "citation_key": "goetz_2025_ai_marketing",
  "authors": [
    "Daniel Goetz"
  ],
  "title": "Can AI Improve Marketing Communications for Small Businesses? Field Evidence from Early Adopters",
  "year": 2025,
  "venue": "working paper",
  "study_design_description": "A difference-in-differences analysis leveraging ChatGPT's introduction as a quasi-natural experiment to identify the effect of LLM adoption on patient demand among mental health care practices. Treated practices rewrote their practice descriptions using ChatGPT during the sample period (February 2023 through March 2024), while control practices rewrote their descriptions without LLM assistance. Propensity score matching was used to balance treatment and control practices on observable characteristics, resulting in 5,310 unique practices in the panel with four control practices matched to each treated practice.",
  "primary_task_description": "Practices supply a free-form written description of roughly 200 words about their practice, which appears at the top of their profile and in platform search results. LLM adoption is defined as the use of ChatGPT to write these descriptions.",
  "population_description": "More than 300,000 private mental health care practices listing themselves on a patient search platform (PsychologyToday.com). The raw panel spans 21 months from July 2022 through March 2024, including observations on 354,412 unique practices. The analysis focuses on 14 months of observations from February 2023 through March 2024. Most therapists operate small private practices, set their own schedules and prices, and can decide whether to accept insurance or receive cash payments.",
  "arms": [
    {
      "arm_name": "chatgpt_adoption",
      "description": "Treated practices that rewrite their practice description during the sample period using ChatGPT",
      "n": null
    },
    {
      "arm_name": "control",
      "description": "Control practices that also re-write their description, but do so without the aid of an LLM",
      "n": null
    }
  ],
  "outcomes": [
    {
      "outcome_name": "waitlist_indicator",
      "outcome_description": "The platform displays an indicator for whether or not a therapy practice has a waitlist, which appears in both the search results and on the therapist's detail page. All else equal, the presence of a waitlist is consistent with greater quantity demanded for that practice.",
      "measurement_unit": "binary indicator (0/1)",
      "is_primary": true
    },
    {
      "outcome_name": "hourly_price",
      "outcome_description": "The hourly price charged by the practice",
      "measurement_unit": "USD per hour",
      "is_primary": false
    }
  ],
