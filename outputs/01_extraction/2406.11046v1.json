{
  "citation_key": "quispe_2024_chatgpt_software",
  "authors": [
    "Alexander Quispe",
    "Rodrigo Grijalba"
  ],
  "title": "Impact of the Availability of Chat-GPT on Software Development Activity",
  "year": 2024,
  "venue": "arXiv preprint",
  "study_design_description": "This study utilizes natural experiments where some governments banned ChatGPT to estimate its effects on software development. The design consists of 120 treatment units and 27 control units, with 11 pre-treatment periods and 2 treatment periods. The authors employ Difference-in-Differences (DID), Synthetic Control (SC), and Synthetic Difference-in-Differences (SDID) methods to analyze quasi-experimental data and estimate ChatGPT's effect on software production in each country-quarter.",
  "primary_task_description": "The study analyzes software development activity using data from GitHub's Innovation Graph, specifically examining the number of pushes per country and per quarter, as well as the number of unique developers in each economy who made at least one git push to a repository with a given programming language.",
  "population_description": "The data spans from the first quarter of 2020 until the first quarter of 2023, covering 151 country units (after dropping 28 units that lacked observations for the whole time span, excluding the EU aggregate and Hong Kong). The treatment period begins in the fourth quarter of 2022, when ChatGPT was initially launched on November 30th.",
  "arms": [
    {
      "arm_name": "chatgpt_available",
      "description": "Countries that were originally announced to have access to ChatGPT at launch",
      "n": 120
    },
    {
      "arm_name": "control",
      "description": "Countries without ChatGPT access during the study period",
      "n": 27
    }
  ],
  "outcomes": [
    {
      "outcome_name": "code_pushes",
      "outcome_description": "The number of times developers in a given economy uploaded code to GitHub per 100,000 people. This metric includes all instances where developers pushed code changes to repositories, whether through the command line or GitHub's online platform, with each push potentially containing multiple commits.",
      "measurement_unit": "pushes per 100,000 people",
      "is_primary": true
    },
    {
      "outcome_name": "repositories",
      "outcome_description": "The number of software projects (repositories) in a given economy per 100,000 people. This metric is based on the modal location of all repository members with triage and above access. It includes all repositories, regardless of whether they are actively developed or maintained.",
      "measurement_unit": "repositories per 100,000 people",
      "is_primary": true
    },
    {
      "outcome_name": "developers",
      "outcome_description": "The number of developer accounts located in a given economy per 100,000 people, based on the modal daily location. This metric excludes bot accounts and users flagged as \"spammy\" within internal systems. It includes developer accounts that may no longer be active.",
      "measurement_unit": "developers per 100,000 people",
      "is_primary": true
    },
