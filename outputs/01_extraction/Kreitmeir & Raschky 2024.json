{
  "citation_key": "kreitmeir_2024_chatgpt_productivity",
  "authors": [
    "David Kreitmeir",
    "Paul A. Raschky"
  ],
  "title": "The Heterogeneous Productivity Effects of Generative AI",
  "year": 2024,
  "venue": "arXiv preprint",
  "study_design_description": "The study exploits Italy's sudden announcement of a ChatGPT ban as a natural experiment to examine the ban's short-run effects on GitHub users' productivity. The authors estimate variants of a difference-in-differences (DID) specification and an event-study specification to check for potential pre-trends and investigate how the estimated effect evolves over time. The analysis compares Italian GitHub users (treatment) to users in Austria, France, and Spain (control) in the week prior to and immediately after the ChatGPT ban in Italy (March 27\u2013April 9, 2023).",
  "primary_task_description": "The study compiles data on the daily coding output quantity and quality of GitHub users. GitHub is the world's largest online code hosting platform used for storage of and joint work on coding projects (repositories). All modifications to a GitHub repository are automatically timestamped and stored, and every action taken by a team member is automatically recorded with details about the kind and substance of the modification, the files and code lines affected, and the date the changes were performed.",
  "population_description": "The study includes over 36,000 GitHub users in Italy and other European countries. The final list of package contributors and owners comprises 483,855 unique GitHub user accounts, of which 5,916 are part of the baseline sample. The analysis stratifies users into \"Less experienced\" (GitHub user accounts created after or in 2017) and \"Experienced\" (accounts created before 2017) samples, as well as a \"Pkg. contributor\" sample comprising GitHub user accounts that are the owner and/or contributor to an analytical programming package repository.",
  "arms": [
    {
      "arm_name": "italian_users_post_ban",
      "description": "Italian users in the first four work days post the ChatGPT ban (Monday 3 April to Thursday 6 April 2023)",
      "n": null
    },
    {
      "arm_name": "control_countries",
      "description": "Users in Austria, France, and Spain during the corresponding pre-period (Monday 27 March to Thursday 30 March 2023)",
      "n": null
    }
  ],
  "outcomes": [
    {
      "outcome_name": "output_quantity_shen",
      "outcome_description": "Aggregate Output as defined by Shen (2023), capturing output quantity",
      "measurement_unit": "binary indicator (1 if any output-related activity recorded on given day, 0 otherwise)",
      "is_primary": true
    },
    {
      "outcome_name": "output_quantity_holub_thies",
      "outcome_description": "Aggregate Output as defined by Holub and Thies (2023), capturing output quantity",
      "measurement_unit": "binary indicator (1 if any output-related activity recorded on given day, 0 otherwise)",
      "is_primary": true
    },
    {
      "outcome_name": "pr_merge_ratio",
      "outcome_description": "Pull request (PR) merge ratio quantifying how many of a user's suggested code edits were accepted by the repository (project) owners. Calculated as (# Closed pull requests that were merged) / (# Pull Requests closed)",
      "measurement_unit": "binary indicator (1 if any PR merge activity recorded on given day, 0 otherwise)",
      "is_primary": true
    },
    {
      "outcome_name": "pr_opened",
      "outcome_description": "Pull requests opened, gauging task choice and complexity",
      "measurement_unit": "binary indicator (1 if any PR opened on given day, 0 otherwise)",
      "is_primary": false
    },
    {
      "outcome_name": "avg_lines_added_per_opened_pr",
      "outcome_description": "Average lines added per opened PR, gauging task choice and complexity",
      "measurement_unit": "binary indicator (1 if any activity recorded on given day, 0 otherwise)",
      "is_primary": false
    },
    {
      "outcome_name": "avg_lines_added_per_merged_pr",
      "outcome_description": "Average lines added per merged PR, gauging task choice and complexity",
      "measurement_unit": "binary indicator (1 if any activity recorded on given day, 0 otherwise)",
      "is_primary": false
    },
    {
      "outcome_name": "easy_issue_closed",
      "outcome_description": "Easy issue closed, gauging task choice and complexity",
      "measurement_unit": "binary indicator (1 if any easy issue closed on given day, 0 otherwise)",
      "is_primary": false
    },
    {
      "outcome_name": "interactive_activity",
      "outcome_description": "Interactive activity, gauging task choice and complexity",
      "measurement_unit": "binary indicator (1 if any interactive activity recorded on given day, 0 otherwise)",
      "is_primary": false
    },
    {
      "outcome_name": "any_event",
      "outcome_description": "Any output-related activity on GitHub",
      "measurement_unit": "binary indicator (1 if any output-related activity recorded on given day, 0 otherwise)",
      "is_primary": false
    },
    {
      "outcome_name": "commit",
      "outcome_description": "Commit activity, alternative measure for output quantity",
      "measurement_unit": "binary indicator (1 if any commit recorded on given day, 0 otherwise)",
      "is_primary": false
    },
    {
      "outcome_name": "pr_merged",
      "outcome_description": "Pull requests merged, alternative measure for output quality",
      "measurement_unit": "binary indicator (1 if any PR merged on given day, 0 otherwise)",
      "is_primary": false
    },
    {
      "outcome_name": "avg_files_edited_per_merged_pr",
      "outcome_description": "Average files edited per merged PR, alternative measure for task complexity",
      "measurement_unit": "binary indicator (1 if any activity recorded on given day, 0 otherwise)",
      "is_primary": false
    }
  ],
